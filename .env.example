# DataForge environment template

# Runtime mode
# local | vercel-ephemeral | persistent
DATAFORGE_RUNTIME_MODE=local

# Optional: explicit DB and raw paths (mainly local/dev)
# DATAFORGE_DB=./db/dataforge.duckdb
# DATAFORGE_RAW_DIR=./data/raw

# Optional: protect /ops/* endpoints
DATAFORGE_OPS_API_KEY=change-me

# Optional: alerting controls
# DATAFORGE_ALERT_WEBHOOK_URL=https://example.com/webhook
# DATAFORGE_ALERT_TRUST_DROP=10
# DATAFORGE_ALERT_TRUST_FLOOR=80
# DATAFORGE_ALERT_DEDUP_MINUTES=30
# DATAFORGE_ESCALATION_MINUTES=60
